---
import WorkspaceLayout from "../layouts/WorkspaceLayout.astro";
import CodeViewer from "../components/CodeViewer.astro";
import {
  getIgnoredPatterns,
  isInternalProtectedPath,
  shouldIgnore,
} from "../lib/ignore";
import fs from "fs";
import path from "path";

// Workspace root - parent of workspace-astro (override with CLAWSPACE_ROOT)
const WORKSPACE_ROOT = path.resolve(
  process.env.CLAWSPACE_ROOT ?? path.resolve(process.cwd(), "..")
);

// Get path from URL
const pathParam = Astro.params.path || "";
const relativePath = pathParam.replace(/^\//, "");
const absolutePath = path.join(WORKSPACE_ROOT, relativePath);

// Security: prevent path traversal
if (!absolutePath.startsWith(WORKSPACE_ROOT)) {
  return Astro.redirect("/");
}

const ignoredPatterns = getIgnoredPatterns(WORKSPACE_ROOT);

// Check if path should be ignored
if (shouldIgnore(relativePath, ignoredPatterns)) {
  return new Response("Forbidden", { status: 403 });
}

// Check if file/directory exists
if (!fs.existsSync(absolutePath)) {
  return new Response("Not Found", { status: 404 });
}

const stats = fs.statSync(absolutePath);

// Handle files
let isFile = false;
let fileContent = "";
let fileName = "";
let fileExt = "";

if (stats.isFile()) {
  isFile = true;
  fileName = path.basename(absolutePath);
  fileExt = path.extname(absolutePath);

  // Binary files - serve directly
  const binaryExts = [
    ".png",
    ".jpg",
    ".jpeg",
    ".gif",
    ".svg",
    ".pdf",
    ".zip",
    ".tar",
    ".gz",
    ".ico",
    ".webp",
  ];

  if (binaryExts.includes(fileExt)) {
    const content = fs.readFileSync(absolutePath);
    const contentTypes: Record<string, string> = {
      ".png": "image/png",
      ".jpg": "image/jpeg",
      ".jpeg": "image/jpeg",
      ".gif": "image/gif",
      ".svg": "image/svg+xml",
      ".webp": "image/webp",
      ".pdf": "application/pdf",
      ".zip": "application/zip",
      ".tar": "application/x-tar",
      ".gz": "application/gzip",
      ".ico": "image/x-icon",
    };

    return new Response(content, {
      headers: {
        "Content-Type": contentTypes[fileExt] || "application/octet-stream",
      },
    });
  }

  // Text-based files - render in template
  fileContent = fs.readFileSync(absolutePath, "utf-8");
}

// Handle directories
let items: Array<{
  name: string;
  type: string;
  path: string;
  canDelete: boolean;
}> = [];

if (!isFile) {
  const files = fs.readdirSync(absolutePath, { withFileTypes: true });
  items = files
    .filter(
      (file) =>
        !shouldIgnore(path.join(relativePath, file.name), ignoredPatterns)
    )
    .map((file) => {
      const itemPath = path.join(relativePath, file.name);
      return {
        name: file.name,
        type: file.isDirectory() ? "directory" : "file",
        path: itemPath,
        canDelete: !isInternalProtectedPath(itemPath),
      };
    })
    .sort((a, b) => {
      if (a.type !== b.type) return a.type === "directory" ? -1 : 1;
      return a.name.localeCompare(b.name);
    });
}

const title = isFile ? `📄 ${fileName}` : `📁 ${relativePath || "Workspace"}`;

// Language mapping for syntax highlighting
const languageMap: Record<string, string> = {
  ".js": "javascript",
  ".mjs": "javascript",
  ".cjs": "javascript",
  ".ts": "typescript",
  ".tsx": "typescript",
  ".jsx": "javascript",
  ".json": "json",
  ".md": "markdown",
  ".yaml": "yaml",
  ".yml": "yaml",
  ".css": "css",
  ".scss": "scss",
  ".html": "html",
  ".sh": "bash",
  ".bash": "bash",
  ".py": "python",
  ".rb": "ruby",
  ".go": "go",
  ".rs": "rust",
  ".java": "java",
  ".xml": "xml",
  ".sql": "sql",
  ".txt": "text",
};

const language = languageMap[fileExt] || "text";

// Build breadcrumbs (include workspace root)
const breadcrumbs: Array<{ label: string; href: string }> = [
  { label: "Workspace", href: "/" },
];

if (relativePath) {
  const pathParts = relativePath.split("/");
  let currentPath = "";

  pathParts.forEach((part) => {
    currentPath += (currentPath ? "/" : "") + part;
    breadcrumbs.push({
      label: part,
      href: `/${currentPath}`,
    });
  });
}
---

<WorkspaceLayout
  title={title}
  metaDesc={`Browse ${title}`}
  breadcrumbs={breadcrumbs}
>
  <div class="workspace-browser">
    {
      isFile ? (
        <div class="file-viewer">
          <CodeViewer
            code={fileContent}
            language={language}
            filename={fileName}
            filePath={relativePath}
            canDelete={!isInternalProtectedPath(relativePath)}
          />
        </div>
      ) : (
        <ul class="space-y-2">
          {items.map((item) => (
            <li class="row-item px-2 border-b border-gray-200 dark:border-gray-700 hover:bg-gray-50 dark:hover:bg-gray-800 focus-within:bg-gray-50 dark:focus-within:bg-gray-800 transition-colors">
              <div class="flex items-center justify-between gap-3 py-2">
                <a
                  href={`/${item.path}`}
                  data-astro-reload={item.type === "file" ? true : undefined}
                  class="row-link flex items-center text-red-600 dark:text-red-400 hover:underline min-w-0"
                >
                  <span class="text-xl mr-2">
                    {item.type === "directory" ? "📂" : "📄"}
                  </span>
                  <span class="truncate">
                    {item.name}
                    {item.type === "directory" ? "/" : ""}
                  </span>
                </a>
                {item.canDelete && (
                  <button
                    type="button"
                    class="delete-entry-btn row-delete-btn p-2 rounded border border-red-300 text-red-700 hover:bg-red-50 dark:border-red-800 dark:text-red-300 dark:hover:bg-red-900/30"
                    data-path={item.path}
                    data-type={item.type}
                    aria-label={`Delete ${item.type === "directory" ? "folder" : "file"} ${item.name}`}
                    title="Delete"
                  >
                    <svg
                      xmlns="http://www.w3.org/2000/svg"
                      width="16"
                      height="16"
                      viewBox="0 0 24 24"
                      fill="none"
                      stroke="currentColor"
                      stroke-width="2"
                      stroke-linecap="round"
                      stroke-linejoin="round"
                      aria-hidden="true"
                    >
                      <path d="M3 6h18" />
                      <path d="M8 6V4a1 1 0 0 1 1-1h6a1 1 0 0 1 1 1v2" />
                      <path d="M19 6v14a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2V6" />
                      <path d="M10 11v6" />
                      <path d="M14 11v6" />
                    </svg>
                    <span class="sr-only">Delete</span>
                  </button>
                )}
              </div>
            </li>
          ))}
        </ul>
      )
    }

    {
      !isFile && items.length === 0 && (
        <p class="text-gray-500 dark:text-gray-400 italic">Empty directory</p>
      )
    }
  </div>
</WorkspaceLayout>

<style is:inline>
  .row-delete-btn {
    opacity: 0;
    pointer-events: none;
    transition: opacity 120ms ease-in-out;
  }

  .row-item:hover .row-delete-btn,
  .row-item:focus-within .row-delete-btn {
    opacity: 1;
    pointer-events: auto;
  }
</style>

<script is:inline>
  async function handleDelete(path, type, button, redirectPath = null) {
    const kind = type === "directory" ? "folder" : "file";
    const confirmed = confirm(
      `Delete ${kind} "${path}"? This cannot be undone.`
    );
    if (!confirmed) return;

    button.disabled = true;

    try {
      const res = await fetch("/api/files/delete", {
        method: "POST",
        headers: { "Content-Type": "application/json" },
        body: JSON.stringify({ path }),
      });

      const payload = await res.json().catch(() => ({}));
      if (!res.ok) {
        alert(`Delete failed: ${payload.error || res.statusText}`);
        return;
      }

      if (redirectPath) {
        window.location.href = redirectPath;
      } else {
        window.location.reload();
      }
    } catch (error) {
      alert(`Delete failed: ${error?.message || error}`);
    } finally {
      button.disabled = false;
    }
  }

  function bindDeleteButtons() {
    document.querySelectorAll(".delete-entry-btn").forEach((button) => {
      if (button.dataset.bound === "true") return;
      button.dataset.bound = "true";
      button.addEventListener("click", () => {
        const path = button.getAttribute("data-path") || "";
        const type = button.getAttribute("data-type") || "file";
        const redirectPath = button.getAttribute("data-redirect");
        if (!path) return;
        handleDelete(path, type, button, redirectPath);
      });
    });
  }

  bindDeleteButtons();
  document.addEventListener("astro:page-load", bindDeleteButtons);
</script>
