---
interface Props {
  code: string;
  language: string;
  filename: string;
  filePath?: string;
}

const { code, language, filename, filePath = "" } = Astro.props;
---

<div
  class="code-viewer not-prose"
  data-file-path={filePath}
  data-language={language}
>
  <div class="code-header">
    <span class="filename text-base">{filename}</span>
    <div class="actions">
      <div class="settings-menu">
        <button
          class="settings-button text-base"
          aria-label="Editor settings"
          title="Settings"
          onclick="toggleEditorSettings(this)"
        >
          <svg
            class="button-icon"
            xmlns="http://www.w3.org/2000/svg"
            width="16"
            height="16"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"
            aria-hidden="true"
          >
            <circle cx="12" cy="12" r="3"></circle>
            <path
              d="M19.4 15a1.65 1.65 0 0 0 .33 1.82l.06.06a2 2 0 0 1 0 2.83 2 2 0 0 1-2.83 0l-.06-.06a1.65 1.65 0 0 0-1.82-.33 1.65 1.65 0 0 0-1 1.51V21a2 2 0 0 1-4 0v-.09a1.65 1.65 0 0 0-1-1.51 1.65 1.65 0 0 0-1.82.33l-.06.06a2 2 0 0 1-2.83 0 2 2 0 0 1 0-2.83l.06-.06a1.65 1.65 0 0 0 .33-1.82 1.65 1.65 0 0 0-1.51-1H3a2 2 0 0 1 0-4h.09a1.65 1.65 0 0 0 1.51-1 1.65 1.65 0 0 0-.33-1.82l-.06-.06a2 2 0 0 1 0-2.83 2 2 0 0 1 2.83 0l.06.06a1.65 1.65 0 0 0 1.82.33h.01a1.65 1.65 0 0 0 .99-1.51V3a2 2 0 0 1 4 0v.09a1.65 1.65 0 0 0 .99 1.51h.01a1.65 1.65 0 0 0 1.82-.33l.06-.06a2 2 0 0 1 2.83 0 2 2 0 0 1 0 2.83l-.06.06a1.65 1.65 0 0 0-.33 1.82v.01a1.65 1.65 0 0 0 1.51.99H21a2 2 0 0 1 0 4h-.09a1.65 1.65 0 0 0-1.51 1z"
            ></path>
          </svg>
          <span class="sr-only">Settings</span>
        </button>
        <div class="settings-panel hidden">
          <label class="settings-item text-base">
            <input
              type="checkbox"
              class="setting-word-wrap"
              onchange="toggleWordWrapSetting(this)"
            />
            Word wrap
          </label>
          <label
            class="settings-item setting-markdown-default-row hidden text-base"
          >
            Default markdown view
            <select
              class="setting-markdown-default text-base"
              onchange="toggleMarkdownDefaultView(this)"
            >
              <option value="edit">Edit</option>
              <option value="preview">Preview</option>
            </select>
          </label>
        </div>
      </div>
      <button
        class="save-button text-base"
        aria-label="Save file"
        title="Save"
        onclick="saveEditor(this)"
      >
        <svg
          class="button-icon"
          xmlns="http://www.w3.org/2000/svg"
          width="16"
          height="16"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"
          aria-hidden="true"
        >
          <path
            d="M19 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h11l5 5v11a2 2 0 0 1-2 2z"
          ></path>
          <polyline points="17 21 17 13 7 13 7 21"></polyline>
          <polyline points="7 3 7 8 15 8"></polyline>
        </svg>
        <span class="sr-only">Save</span>
      </button>
      <button
        class="revert-button text-base"
        aria-label="Revert changes"
        title="Revert"
        onclick="revertEditor(this)"
      >
        <svg
          class="button-icon"
          xmlns="http://www.w3.org/2000/svg"
          width="16"
          height="16"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"
          aria-hidden="true"
        >
          <path d="M9 14 4 9l5-5"></path>
          <path d="M4 9h10a6 6 0 1 1 0 12h-1"></path>
        </svg>
        <span class="sr-only">Revert</span>
      </button>
      <button
        class="copy-button text-base"
        aria-label="Copy to clipboard"
        title="Copy"
        onclick="copyToClipboard(this)"
      >
        <svg
          class="copy-icon"
          xmlns="http://www.w3.org/2000/svg"
          width="16"
          height="16"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"
        >
          <rect width="14" height="14" x="8" y="8" rx="2" ry="2"></rect>
          <path d="M4 16c-1.1 0-2-.9-2-2V4c0-1.1.9-2 2-2h10c1.1 0 2 .9 2 2"
          ></path>
        </svg>
        <svg
          class="check-icon hidden"
          xmlns="http://www.w3.org/2000/svg"
          width="16"
          height="16"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"
        >
          <polyline points="20 6 9 17 4 12"></polyline>
        </svg>
        <span class="copy-text sr-only">Copy</span>
        <span class="copied-text sr-only hidden">Copied!</span>
      </button>
    </div>
  </div>
  <div class="code-content">
    <div class="editor-tabs hidden">
      <button
        type="button"
        class="editor-tab is-active text-base"
        data-tab="edit"
        onclick="switchEditorTab(this, 'edit')"
      >
        Edit
      </button>
      <button
        type="button"
        class="editor-tab text-base"
        data-tab="preview"
        onclick="switchEditorTab(this, 'preview')"
      >
        Preview
      </button>
    </div>
    <div class="editor-pane" data-pane="edit">
      <div class="editor" style="height: 70vh"></div>
      <textarea class="editor-fallback hidden text-base">{code}</textarea>
    </div>
    <div class="markdown-preview hidden" data-pane="preview">
      <div class="markdown-preview-content"></div>
    </div>
  </div>
</div>

<style>
  .code-viewer {
    border-radius: 0.5rem;
    overflow: hidden;
    border: 1px solid rgb(229 231 235);
    background: rgb(249 250 251);
  }

  :global(.dark) .code-viewer {
    border-color: rgb(55 65 81);
    background: rgb(17 24 39);
  }

  .code-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 0.75rem 1rem;
    border-bottom: 1px solid rgb(229 231 235);
    background: rgb(243 244 246);
  }

  :global(.dark) .code-header {
    border-bottom-color: rgb(55 65 81);
    background: rgb(31 41 55);
  }

  .filename {
    font-family:
      ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, monospace;
    font-size: 1rem;
    color: rgb(75 85 99);
  }

  :global(.dark) .filename {
    color: rgb(156 163 175);
  }

  .actions {
    display: flex;
    gap: 0.5rem;
    align-items: center;
  }

  .copy-button,
  .save-button,
  .revert-button,
  .settings-button {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0.375rem;
    padding: 0.375rem 0.625rem;
    font-size: 1rem;
    border-radius: 0.375rem;
    border: 1px solid rgb(209 213 219);
    background: white;
    color: rgb(75 85 99);
    cursor: pointer;
    transition: all 0.2s;
  }

  .button-icon {
    width: 16px;
    height: 16px;
    flex-shrink: 0;
  }

  .copy-button:hover,
  .save-button:hover,
  .revert-button:hover,
  .settings-button:hover {
    background: rgb(249 250 251);
    border-color: rgb(156 163 175);
  }

  :global(.dark) .copy-button,
  :global(.dark) .save-button,
  :global(.dark) .revert-button,
  :global(.dark) .settings-button {
    background: rgb(55 65 81);
    border-color: rgb(75 85 99);
    color: rgb(209 213 219);
  }

  :global(.dark) .copy-button:hover,
  :global(.dark) .save-button:hover,
  :global(.dark) .revert-button:hover,
  :global(.dark) .settings-button:hover {
    background: rgb(75 85 99);
    border-color: rgb(107 114 128);
  }

  .settings-menu {
    position: relative;
  }

  .settings-panel {
    position: absolute;
    right: 0;
    top: calc(100% + 0.375rem);
    min-width: 9rem;
    border: 1px solid rgb(209 213 219);
    border-radius: 0.375rem;
    background: white;
    box-shadow: 0 10px 24px rgb(0 0 0 / 0.12);
    padding: 0.5rem;
    z-index: 10;
  }

  :global(.dark) .settings-panel {
    background: rgb(31 41 55);
    border-color: rgb(75 85 99);
  }

  .settings-item {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 1rem;
    color: rgb(55 65 81);
    cursor: pointer;
  }

  :global(.dark) .settings-item {
    color: rgb(209 213 219);
  }

  .code-content {
    padding: 1rem;
  }

  .editor-tabs {
    display: flex;
    gap: 0.5rem;
    margin-bottom: 0.75rem;
  }

  .editor-tab {
    border: 1px solid rgb(209 213 219);
    background: white;
    color: rgb(75 85 99);
    border-radius: 0.375rem;
    padding: 0.25rem 0.625rem;
    font-size: 1rem;
    cursor: pointer;
  }

  .editor-tab.is-active {
    border-color: rgb(59 130 246);
    color: rgb(29 78 216);
    background: rgb(239 246 255);
  }

  :global(.dark) .editor-tab {
    background: rgb(55 65 81);
    border-color: rgb(75 85 99);
    color: rgb(209 213 219);
  }

  :global(.dark) .editor-tab.is-active {
    background: rgb(30 41 59);
    border-color: rgb(96 165 250);
    color: rgb(147 197 253);
  }

  .markdown-preview {
    min-height: 70vh;
    margin-top: 0;
    border: 1px solid rgb(209 213 219);
    border-radius: 0.375rem;
    padding: 1rem;
    background: rgb(255 255 255);
    color: rgb(31 41 55);
    overflow-wrap: anywhere;
  }

  .markdown-preview-content :global(h1),
  .markdown-preview-content :global(h2),
  .markdown-preview-content :global(h3) {
    margin-top: 1.1em;
    margin-bottom: 0.4em;
  }

  .markdown-preview-content :global(p),
  .markdown-preview-content :global(ul),
  .markdown-preview-content :global(ol),
  .markdown-preview-content :global(pre),
  .markdown-preview-content :global(blockquote) {
    margin: 0.5em 0;
  }

  .markdown-preview-content :global(pre) {
    padding: 0.75rem;
    border-radius: 0.375rem;
    background: rgb(243 244 246);
    overflow-x: auto;
  }

  .markdown-preview-content :global(code) {
    font-family:
      ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, monospace;
  }

  :global(.dark) .markdown-preview {
    background: rgb(17 24 39);
    color: rgb(229 231 235);
    border-color: rgb(75 85 99);
  }

  :global(.dark) .markdown-preview-content :global(pre) {
    background: rgb(30 41 59);
  }

  .editor-fallback {
    width: 100%;
    min-height: 70vh;
    font-family:
      ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, monospace;
    font-size: 1rem;
    border: 1px solid rgb(209 213 219);
    border-radius: 0.375rem;
    padding: 0.75rem;
    background: rgb(255 255 255);
    color: rgb(31 41 55);
  }

  :global(.dark) .editor-fallback {
    background: rgb(17 24 39);
    color: rgb(229 231 235);
    border-color: rgb(75 85 99);
  }

  .code-viewer {
    animation: editorEnter 180ms ease-out;
  }

  .editor {
    animation: editorContentFade 220ms ease-out;
  }

  :global(.dark) .code-viewer :global(.monaco-editor),
  :global(.dark) .code-viewer :global(.monaco-editor .margin),
  :global(.dark) .code-viewer :global(.monaco-editor-background) {
    background-color: rgb(17 24 39) !important;
  }

  :global(.dark) .code-viewer :global(.monaco-editor .line-numbers) {
    color: rgb(148 163 184) !important;
  }

  :global(.dark) .code-viewer :global(.monaco-editor .cursor) {
    border-left-color: rgb(226 232 240) !important;
  }

  :global(.dark) .code-viewer :global(.monaco-editor .current-line),
  :global(.dark)
    .code-viewer
    :global(.monaco-editor .view-overlays .current-line) {
    background-color: rgb(30 41 59) !important;
  }

  :global(.dark) .code-viewer :global(.monaco-editor .selected-text) {
    background-color: rgb(51 65 85) !important;
  }

  @keyframes editorEnter {
    from {
      opacity: 0;
      transform: translateY(6px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  @keyframes editorContentFade {
    from {
      opacity: 0.7;
    }
    to {
      opacity: 1;
    }
  }

  .sr-only {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
    border: 0;
  }

  .hidden {
    display: none;
  }

  @media (max-width: 768px) {
    .code-viewer .settings-item,
    .code-viewer .editor-tab,
    .code-viewer .settings-button,
    .code-viewer .save-button,
    .code-viewer .revert-button,
    .code-viewer .copy-button,
    .code-viewer :is(input, select, textarea) {
      font-size: 16px;
    }
  }
</style>

<script is:inline>
  let editors = window.__clawspaceEditors || new WeakMap();
  window.__clawspaceEditors = editors;
  const editorStates = window.__clawspaceEditorStates || new Set();
  window.__clawspaceEditorStates = editorStates;

  const monacoLanguageMap = {
    javascript: "javascript",
    typescript: "typescript",
    json: "json",
    markdown: "markdown",
    yaml: "yaml",
    css: "css",
    scss: "scss",
    html: "html",
    bash: "shell",
    python: "python",
    sql: "sql",
    xml: "xml",
    text: "plaintext",
  };

  const prettierParserMap = {
    javascript: "babel",
    typescript: "typescript",
    json: "json",
    markdown: "markdown",
    yaml: "yaml",
    css: "css",
    scss: "scss",
    html: "html",
  };

  const editorSettingsStorageKey = "clawspace.editor.settings.v1";

  function getMobileSafeFontSize() {
    if (typeof window === "undefined") return 14;
    return window.matchMedia("(max-width: 768px)").matches ? 16 : 14;
  }
  let markedLibPromise = null;

  const monacoThemeState = window.__clawspaceMonacoThemeState || {
    current: null,
  };
  window.__clawspaceMonacoThemeState = monacoThemeState;

  function getMonacoTheme() {
    return document.documentElement.classList.contains("dark")
      ? "vs-dark"
      : "vs";
  }

  function applyMonacoTheme(theme) {
    if (!window.monaco || monacoThemeState.current === theme) return;
    window.monaco.editor.setTheme(theme);
    monacoThemeState.current = theme;
  }

  function ensureMonacoThemeObserver() {
    if (window.__clawspaceMonacoThemeObserver) return;
    const observer = new MutationObserver(() => {
      applyMonacoTheme(getMonacoTheme());
    });
    observer.observe(document.documentElement, {
      attributes: true,
      attributeFilter: ["class"],
    });
    window.__clawspaceMonacoThemeObserver = observer;
  }

  function ensureMonacoThemeListener() {
    if (window.__clawspaceMonacoThemeListener) return;
    document.addEventListener("clawspace:theme-change", (event) => {
      const theme = event?.detail?.theme === "dark" ? "vs-dark" : "vs";
      applyMonacoTheme(theme);
    });
    window.__clawspaceMonacoThemeListener = true;
  }

  function getEditorSettings() {
    const defaults = { wordWrap: true, markdownDefaultView: "edit" };
    try {
      const raw = localStorage.getItem(editorSettingsStorageKey);
      if (!raw) return defaults;
      const parsed = JSON.parse(raw) || {};
      const markdownDefaultView =
        parsed.markdownDefaultView === "preview" ? "preview" : "edit";
      return {
        wordWrap: parsed.wordWrap ?? defaults.wordWrap,
        markdownDefaultView,
      };
    } catch {
      return defaults;
    }
  }

  function setEditorSettings(next) {
    const settings = { ...getEditorSettings(), ...next };
    try {
      localStorage.setItem(editorSettingsStorageKey, JSON.stringify(settings));
    } catch (_err) {
      /* noop */
    }
    return settings;
  }

  function applyWordWrap(root, state, enabled) {
    if (state?.monaco && state?.editor) {
      state.editor.updateOptions({ wordWrap: enabled ? "on" : "off" });
    }

    const fallback = root?.querySelector(".editor-fallback");
    if (fallback) {
      fallback.style.whiteSpace = enabled ? "pre-wrap" : "pre";
      fallback.style.overflowWrap = enabled ? "anywhere" : "normal";
      fallback.style.overflowX = enabled ? "hidden" : "auto";
    }
  }

  function isMarkdownRoot(root) {
    return getRawLanguage(root) === "markdown";
  }

  function getDefaultMarkdownTab(settings = getEditorSettings()) {
    return settings?.markdownDefaultView === "preview" ? "preview" : "edit";
  }

  function syncSettingsPanel(root, settings) {
    const wordWrap = root?.querySelector(".setting-word-wrap");
    if (wordWrap) {
      wordWrap.checked = Boolean(settings?.wordWrap);
    }

    const markdownDefaultRow = root?.querySelector(
      ".setting-markdown-default-row"
    );
    const markdownDefault = root?.querySelector(".setting-markdown-default");
    const isMarkdown = isMarkdownRoot(root);

    if (markdownDefaultRow) {
      markdownDefaultRow.classList.toggle("hidden", !isMarkdown);
    }

    if (markdownDefault) {
      markdownDefault.value = getDefaultMarkdownTab(settings);
    }
  }

  async function ensureMarked() {
    if (window.marked) return window.marked;
    if (!markedLibPromise) {
      markedLibPromise = import("https://esm.sh/marked@12.0.2").then(
        (mod) => mod.marked
      );
    }
    const marked = await markedLibPromise;
    window.marked = marked;
    return marked;
  }

  function sanitizePreviewAnchors(root) {
    root?.querySelectorAll("a[href]").forEach((a) => {
      a.setAttribute("target", "_blank");
      a.setAttribute("rel", "noopener noreferrer");
    });
  }

  async function renderMarkdownPreview(root, state) {
    if (!isMarkdownRoot(root)) return;
    const container = root?.querySelector(".markdown-preview-content");
    if (!container) return;

    try {
      const marked = await ensureMarked();
      const content = getCurrentContent(root, state);
      container.innerHTML = marked.parse(content || "");
      sanitizePreviewAnchors(container);
    } catch {
      container.textContent = getCurrentContent(root, state);
    }
  }

  function setEditorTab(root, tab) {
    const tabs = root?.querySelectorAll(".editor-tab");
    const editPane = root?.querySelector('.editor-pane[data-pane="edit"]');
    const previewPane = root?.querySelector(
      '.markdown-preview[data-pane="preview"]'
    );

    const isPreview = tab === "preview";

    tabs?.forEach((btn) => {
      btn.classList.toggle("is-active", btn.getAttribute("data-tab") === tab);
    });

    if (editPane) editPane.classList.toggle("hidden", isPreview);
    if (previewPane) previewPane.classList.toggle("hidden", !isPreview);

    if (isPreview) {
      renderMarkdownPreview(root, editors.get(root));
    }
  }

  function applyMarkdownPreview(root, state) {
    const tabs = root?.querySelector(".editor-tabs");
    const previewPane = root?.querySelector(
      '.markdown-preview[data-pane="preview"]'
    );
    if (!tabs || !previewPane) return;

    const showTabs = isMarkdownRoot(root);
    tabs.classList.toggle("hidden", !showTabs);

    if (!showTabs) {
      setEditorTab(root, "edit");
      return;
    }

    const defaultTab = getDefaultMarkdownTab();
    setEditorTab(root, defaultTab);
    if (state && defaultTab === "preview") {
      renderMarkdownPreview(root, state);
    }
  }

  async function ensureMonaco() {
    if (window.monaco) return window.monaco;
    if (!window.require) {
      await new Promise((resolve, reject) => {
        const script = document.createElement("script");
        script.src =
          "https://cdn.jsdelivr.net/npm/monaco-editor@0.52.2/min/vs/loader.js";
        script.onload = resolve;
        script.onerror = reject;
        document.head.appendChild(script);
      });
    }
    return await new Promise((resolve) => {
      window.require.config({
        paths: {
          vs: "https://cdn.jsdelivr.net/npm/monaco-editor@0.52.2/min/vs",
        },
      });
      window.require(["vs/editor/editor.main"], () => resolve(window.monaco));
    });
  }

  function getRawLanguage(root) {
    return root.getAttribute("data-language") || "text";
  }

  function getEditorLanguage(root) {
    return monacoLanguageMap[getRawLanguage(root)] || "plaintext";
  }

  function getInitialContent(root) {
    const fallback = root?.querySelector(".editor-fallback");
    return (
      fallback?.defaultValue ?? fallback?.textContent ?? fallback?.value ?? ""
    );
  }

  function getCurrentContent(root, state) {
    if (state?.monaco && state?.editor) {
      return state.editor.getValue();
    }
    const fallback = root?.querySelector(".editor-fallback");
    return (
      fallback?.value ?? fallback?.defaultValue ?? fallback?.textContent ?? ""
    );
  }

  async function ensurePrettier() {
    if (window.prettier && window.prettierPlugins) return;
    await import("https://esm.sh/prettier@3.3.3/standalone").then((m) => {
      window.prettier = m.default;
    });
    const [babel, estree, typescript, postcss, markdown, html, yaml] =
      await Promise.all([
        import("https://esm.sh/prettier@3.3.3/plugins/babel"),
        import("https://esm.sh/prettier@3.3.3/plugins/estree"),
        import("https://esm.sh/prettier@3.3.3/plugins/typescript"),
        import("https://esm.sh/prettier@3.3.3/plugins/postcss"),
        import("https://esm.sh/prettier@3.3.3/plugins/markdown"),
        import("https://esm.sh/prettier@3.3.3/plugins/html"),
        import("https://esm.sh/prettier@3.3.3/plugins/yaml"),
      ]);
    window.prettierPlugins = [
      babel.default,
      estree.default,
      typescript.default,
      postcss.default,
      markdown.default,
      html.default,
      yaml.default,
    ];
  }

  function clearEditorMarkers(state) {
    if (!state?.monaco || !state?.editor || !window.monaco) return;
    const model = state.editor.getModel();
    if (!model) return;
    window.monaco.editor.setModelMarkers(model, "clawspace-prettier", []);
  }

  function setEditorErrorMarker(state, err) {
    if (!state?.monaco || !state?.editor || !window.monaco) return;
    const model = state.editor.getModel();
    if (!model) return;

    const message = String(err?.message || err || "Format failed");
    const loc = err?.loc?.start || {};
    const match = message.match(/\((\d+):(\d+)\)/);
    const line = Number(loc.line || (match ? match[1] : 1));
    const col = Number(loc.column || (match ? match[2] : 1));

    window.monaco.editor.setModelMarkers(model, "clawspace-prettier", [
      {
        severity: window.monaco.MarkerSeverity.Error,
        message,
        startLineNumber: Math.max(1, line),
        startColumn: Math.max(1, col),
        endLineNumber: Math.max(1, line),
        endColumn: Math.max(2, col + 1),
      },
    ]);
  }

  async function formatRoot(root, { silent = false } = {}) {
    const state = editors.get(root);
    const parser = prettierParserMap[getRawLanguage(root)];
    if (!parser) {
      if (!silent) alert("Prettier is not supported for this file type yet.");
      return false;
    }

    const content = getCurrentContent(root, state);

    try {
      await ensurePrettier();
      const formatted = await window.prettier.format(content, {
        parser,
        plugins: window.prettierPlugins,
      });
      if (state?.monaco) state.editor.setValue(formatted);
      else root.querySelector(".editor-fallback").value = formatted;
      clearEditorMarkers(state);
      return true;
    } catch (_err) {
      setEditorErrorMarker(state, _err);
      if (!state?.monaco && !silent)
        alert(`Format failed: ${_err.message || _err}`);
      return false;
    }
  }

  async function initEditor(root) {
    if (!root || editors.get(root)) return;
    const editorEl = root.querySelector(".editor");
    const fallback = root.querySelector(".editor-fallback");
    const initialText = getInitialContent(root);
    const settings = getEditorSettings();
    syncSettingsPanel(root, settings);

    try {
      const monaco = await ensureMonaco();
      const theme = getMonacoTheme();
      applyMonacoTheme(theme);
      ensureMonacoThemeObserver();
      ensureMonacoThemeListener();
      const editor = monaco.editor.create(editorEl, {
        value: initialText,
        language: getEditorLanguage(root),
        automaticLayout: true,
        minimap: { enabled: false },
        wordWrap: settings.wordWrap ? "on" : "off",
        fontSize: getMobileSafeFontSize(),
        theme,
      });

      // Monaco + view transitions: relayout burst to catch late container sizing
      const layoutBurst = [0, 50, 150, 300];
      layoutBurst.forEach((delay) => {
        setTimeout(() => {
          try {
            editor.layout();
          } catch (_err) {
            /* noop */
          }
        }, delay);
      });

      editor.onDidBlurEditorText(() => {
        formatRoot(root, { silent: true });
      });
      editor.onDidChangeModelContent(() => {
        clearEditorMarkers(editors.get(root));
        if (isMarkdownRoot(root)) {
          renderMarkdownPreview(root, editors.get(root));
        }
      });

      let resizeObserver = null;
      if (typeof ResizeObserver !== "undefined") {
        resizeObserver = new ResizeObserver(() => {
          try {
            editor.layout();
          } catch (_err) {
            /* noop */
          }
        });
        resizeObserver.observe(editorEl);
      }

      const state = {
        monaco: true,
        editor,
        original: initialText,
        resizeObserver,
      };
      editors.set(root, state);
      editorStates.add(state);
      applyWordWrap(root, state, settings.wordWrap);
      applyMarkdownPreview(root, state);
    } catch {
      editorEl.classList.add("hidden");
      fallback.classList.remove("hidden");
      fallback.addEventListener("blur", () => {
        formatRoot(root, { silent: true });
      });
      fallback.addEventListener("input", () => {
        if (isMarkdownRoot(root)) {
          renderMarkdownPreview(root, editors.get(root));
        }
      });
      const state = { monaco: false, original: initialText };
      editors.set(root, state);
      editorStates.add(state);
      applyWordWrap(root, state, settings.wordWrap);
      applyMarkdownPreview(root, state);
    }
  }

  function closeAllSettingsPanels() {
    document.querySelectorAll(".settings-panel").forEach((panel) => {
      panel.classList.add("hidden");
    });
  }

  // eslint-disable-next-line @typescript-eslint/no-unused-vars
  function toggleEditorSettings(button) {
    const menu = button.closest(".settings-menu");
    const panel = menu?.querySelector(".settings-panel");
    if (!panel) return;

    const isHidden = panel.classList.contains("hidden");
    closeAllSettingsPanels();
    if (isHidden) panel.classList.remove("hidden");
  }

  // eslint-disable-next-line @typescript-eslint/no-unused-vars
  function toggleWordWrapSetting(input) {
    const root = input.closest(".code-viewer");
    const state = editors.get(root);
    const settings = setEditorSettings({ wordWrap: input.checked });
    applyWordWrap(root, state, settings.wordWrap);
  }

  // eslint-disable-next-line @typescript-eslint/no-unused-vars
  function toggleMarkdownDefaultView(select) {
    const root = select.closest(".code-viewer");
    const state = editors.get(root);
    const settings = setEditorSettings({ markdownDefaultView: select.value });
    applyMarkdownPreview(root, state);
    syncSettingsPanel(root, settings);
  }

  // eslint-disable-next-line @typescript-eslint/no-unused-vars
  function switchEditorTab(button, tab) {
    const root = button.closest(".code-viewer");
    if (!isMarkdownRoot(root)) return;
    setEditorTab(root, tab);
  }

  document.addEventListener("click", (event) => {
    if (!event.target.closest(".settings-menu")) {
      closeAllSettingsPanels();
    }
  });

  function getRootFromButton(button) {
    return button.closest(".code-viewer");
  }

  // eslint-disable-next-line @typescript-eslint/no-unused-vars
  async function saveEditor(button) {
    const root = getRootFromButton(button);
    const state = editors.get(root);
    const filePath = root?.getAttribute("data-file-path");
    if (!root || !filePath) {
      alert("Missing file path");
      return;
    }

    const content = getCurrentContent(root, state);

    const res = await fetch("/api/files/save", {
      method: "POST",
      headers: { "Content-Type": "application/json" },
      body: JSON.stringify({ path: filePath, content }),
    });

    if (!res.ok) {
      const payload = await res.json().catch(() => ({}));
      alert(`Save failed: ${payload.error || res.statusText}`);
      return;
    }
    if (state) {
      state.original = content;
    }
  }

  // eslint-disable-next-line @typescript-eslint/no-unused-vars
  function revertEditor(button) {
    const root = getRootFromButton(button);
    const state = editors.get(root);
    if (!root || !state) return;

    const original = state.original ?? "";
    if (state.monaco && state.editor) {
      state.editor.setValue(original);
    } else {
      const fallback = root.querySelector(".editor-fallback");
      if (fallback) fallback.value = original;
    }
  }

  // eslint-disable-next-line @typescript-eslint/no-unused-vars
  async function copyToClipboard(button) {
    const root = getRootFromButton(button);
    const state = editors.get(root);
    const code = getCurrentContent(root, state);
    if (!code) return;

    try {
      await navigator.clipboard.writeText(code);
      const copyIcon = button.querySelector(".copy-icon");
      const checkIcon = button.querySelector(".check-icon");
      const copyText = button.querySelector(".copy-text");
      const copiedText = button.querySelector(".copied-text");

      if (copyIcon) copyIcon.classList.add("hidden");
      if (checkIcon) checkIcon.classList.remove("hidden");
      if (copyText) copyText.classList.add("hidden");
      if (copiedText) copiedText.classList.remove("hidden");

      setTimeout(() => {
        if (copyIcon) copyIcon.classList.remove("hidden");
        if (checkIcon) checkIcon.classList.add("hidden");
        if (copyText) copyText.classList.remove("hidden");
        if (copiedText) copiedText.classList.add("hidden");
      }, 2000);
    } catch (_err) {
      alert("Failed to copy to clipboard. Error: " + _err.message);
    }
  }

  function initAllEditors() {
    document.querySelectorAll(".code-viewer").forEach((root) => {
      initEditor(root);
    });
  }

  function relayoutAllEditorsBurst() {
    const delays = [0, 50, 150, 300];
    delays.forEach((delay) => {
      setTimeout(() => {
        editorStates.forEach((state) => {
          if (state?.monaco && state?.editor) {
            try {
              state.editor.updateOptions({ fontSize: getMobileSafeFontSize() });
              state.editor.layout();
            } catch (_err) {
              /* noop */
            }
          }
        });
      }, delay);
    });
  }

  function disposeAllEditors() {
    editorStates.forEach((state) => {
      if (state?.resizeObserver) {
        try {
          state.resizeObserver.disconnect();
        } catch (_err) {
          /* noop */
        }
      }
      if (state?.monaco && state?.editor) {
        try {
          state.editor.dispose();
        } catch (_err) {
          /* noop */
        }
      }
    });
    editorStates.clear();
    editors = new WeakMap();
    window.__clawspaceEditors = editors;
  }

  window.__clawspaceReinitEditors = () => {
    disposeAllEditors();
    initAllEditors();
    relayoutAllEditorsBurst();
  };

  function scheduleInitAllEditors() {
    const previous = window.__clawspaceInitTimer;
    if (previous) {
      clearTimeout(previous);
    }

    requestAnimationFrame(() => {
      requestAnimationFrame(() => {
        const timer = setTimeout(() => {
          initAllEditors();
          window.__clawspaceInitTimer = null;
        }, 40);
        window.__clawspaceInitTimer = timer;
      });
    });
  }

  // Astro view transitions lifecycle
  if (!window.__clawspaceLifecycleBound) {
    document.addEventListener("astro:before-swap", () => {
      disposeAllEditors();
    });

    document.addEventListener("astro:page-load", () => {
      scheduleInitAllEditors();
      relayoutAllEditorsBurst();
    });

    window.__clawspaceLifecycleBound = true;
  }
</script>
